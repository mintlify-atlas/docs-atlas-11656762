  "keyFeatures": [
    "300+ pre-built connectors for APIs, databases, data warehouses, and data lakes",
    "Low-code and Python Connector Development Kits (CDKs) for building custom connectors",
    "Temporal-powered workflow orchestration for reliable sync scheduling",
    "Kubernetes Helm chart deployment for production-grade infrastructure",
    "Comprehensive REST API for programmatic control of all platform resources",
    "Feature flag system supporting LaunchDarkly, config files, and custom backends",
    "Built-in OAuth support for connector authentication",
    "Multi-workspace and multi-organization tenancy with RBAC permissions",
    "Airbyte Embedded for white-label data integration via config templates",
    "Real-time audit logging and metrics reporting"
  ],
  "publicApiSurface": [
    "GET/POST /sources — Manage data sources",
    "GET/POST /destinations — Manage data destinations",
    "GET/POST /connections — Manage sync connections",
    "GET/POST /jobs — Trigger and monitor sync jobs",
    "GET/POST /workspaces — Manage workspaces",
    "GET/POST /organizations — Manage organizations",
    "GET/POST /permissions — Manage user permissions",
    "GET/POST /applications — Manage OAuth applications",
    "GET/POST /dataplanes — Manage data plane infrastructure",
    "GET/POST /config_templates/sources — Airbyte Embedded config templates",
    "POST /sources/initiateOAuth — Initiate OAuth for sources",
    "GET /connector_definitions — List available connector definitions",
    "GET /health — Platform health check"
  ]
}
